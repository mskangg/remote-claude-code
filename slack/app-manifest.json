{
  "_metadata": {
    "major_version": 2,
    "minor_version": 1
  },
  "display_information": {
    "name": "Remote Claude Code",
    "description": "Run Claude Code in your real environment and continue it from anywhere.",
    "background_color": "#1f2937"
  },
  "features": {
    "bot_user": {
      "display_name": "Remote Claude Code",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/cc",
        "description": "Open or control a Claude Code session",
        "usage_hint": "[start]",
        "should_escape": false
      },
      {
        "command": "/cx",
        "description": "Open or control a Codex session",
        "usage_hint": "[start]",
        "should_escape": false
      },
      {
        "command": "/gm",
        "description": "Open or control a Gemini CLI session",
        "usage_hint": "[start]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "chat:write",
        "chat:write.public",
        "commands"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true
    },
    "socket_mode_enabled": true,
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.channels"
      ]
    },
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
